import java.util.*;
class missingnumber
{
    int missingNum(int arr[]) {
        
        int n = arr.length + 1;
        boolean[] visited = new boolean[n + 1];

        for(int i = 0; i < arr.length; i++){
            visited[arr[i]] = true;
        }

        for(int i = 1; i <= n; i++){
            if(!visited[i]){
                return i;
            }
        }

        return -1;
    }
}
