import java.util.*;
class gfg2 {
    int missingNum(int arr[]) {
       int n = arr.length+1;
       int totalsum =n = n*(n+1)/2 ;
       int arrsum = 0;
       for(int i = 0 ; i < arr.length ; i++)
       {
          arrsum += arr[i]; 
           
        }
       return totalsum - arrsum ;
        
    }
}
